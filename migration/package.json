{
  "name": "bolao-firestore-migration",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dry-run": "node migrate-resultados.cjs",
    "verify": "node migrate-resultados.cjs --verify-target",
    "test": "node --test migrate-resultados.test.cjs",
    "validate-rules": "firebase emulators:exec --config ../firebase.json --only firestore --project demo-bolao \"node --version\"",
    "test:rules": "set FIRESTORE_EMULATOR_HOST=127.0.0.1:8383&& firebase emulators:exec --config ../firebase.test.json --only firestore --project demo-bolao \"node --test firestore.rules.test.cjs\""
  },
  "dependencies": {
    "firebase-admin": "^13.4.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.14.0",
    "firebase-tools": "^15.20.0"
  }
}
